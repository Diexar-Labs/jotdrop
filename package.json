{
  "name": "jotdrop",
  "version": "0.1.0",
  "description": "A private, open-source Google Keep alternative for Obsidian: a trio of quick-capture card grid, companion Android app, and Chrome web clipper. Install all three for the full Keep experience.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": ["obsidian", "plugin", "notes", "keep"],
  "author": "Diexar Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Diexar-Labs/jotdrop.git"
  },
  "bugs": {
    "url": "https://github.com/Diexar-Labs/jotdrop/issues"
  },
  "homepage": "https://github.com/Diexar-Labs/jotdrop#readme",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.2",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5"
  }
}
